# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env file - it is listed in .gitignore.

# Web server
PORT=3000

# Amazon RDS (MySQL) connection
DB_HOST=your-db-instance.xxxxxxxxxx.me-south-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=change-me
DB_NAME=lostfound

# Amazon S3 (item photos)
AWS_REGION=me-south-1
S3_BUCKET=auk-lostfound-photos-<your-unique-suffix>

# NOTE ON AWS CREDENTIALS:
# On EC2 we do NOT put access keys anywhere. The instance has an IAM role
# (LostFoundEC2Role) attached, and the AWS SDK picks up temporary credentials
# from the instance metadata service automatically.
# For local development only, you can configure a profile with `aws configure`.
